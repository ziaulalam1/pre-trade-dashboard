{
  "name": "pre-trade-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "ticks": "ts-node src/tickServer.ts",
    "test": "jest --testPathPattern=tests/",
    "benchmark": "ts-node --compiler-options '{\"module\":\"commonjs\",\"target\":\"ES2020\",\"strict\":true,\"esModuleInterop\":true}' ../scripts/benchmark.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/../tests"
    ]
  }
